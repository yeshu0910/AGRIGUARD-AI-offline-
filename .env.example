# AgriGuard AI Environment Configuration
# Copy this file to .env and fill in real values before running the application.
# Never commit .env to version control.

# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-me-with-a-strong-random-secret

# Paths (relative to project root)
MODEL_PATH=models/crop_disease_model.tflite
LLM_MODEL_PATH=models/phi-3-mini-4k-instruct-q4.gguf
LABELS_PATH=models/labels.txt
DB_PATH=database/agriguard.db

# Limits
MAX_UPLOAD_SIZE_MB=10
MAX_IMAGE_DIM=1024

# Inference
TFLITE_THREADS=4
LLM_THREADS=4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_TOP_P=0.9

# CORS (comma-separated origins for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
